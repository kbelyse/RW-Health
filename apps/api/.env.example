NODE_ENV=development
WEB_DIST=
PORT=4000 
DATABASE_URL=file:./dev.db
JWT_SECRET=local-dev-only-replace-with-random-string-32chars!!
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# EMAIL (SMTP) — optional
# -----------------------------------------------------------------------------
# The API uses Nodemailer. Real mail is sent ONLY if ALL of these are non-empty:
#   SMTP_HOST, SMTP_USER, SMTP_PASS
# If any is missing, emails are printed to the API terminal instead (fine for local dev).
#
# Used for: welcome, password reset, appointment notifications, lab/visit notices.
#
# --- Quick setup (Gmail) ---
# 1. Google Account → Security → enable "2-Step Verification".
# 2. Security → App passwords → create → choose Mail / Other → copy the 16-char password.
# 3. Fill in below (use YOUR address). SMTP_SECURE=false with port 587 is correct for Gmail.
# 4. Restart the API after saving.
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=abcdabcdabcdabcd
# SMTP_FROM="RW-Health Passport <you@gmail.com>"
# SMTP_SECURE=false
#
# --- Outlook / Microsoft 365 (typical) ---
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=you@outlook.com
# SMTP_PASS=your-password
# SMTP_FROM="RW-Health Passport <you@outlook.com>"
# SMTP_SECURE=false
#
# --- Ports ---
# 587 = STARTTLS (set SMTP_SECURE=false) — most common
# 465 = SSL/TLS (set SMTP_SECURE=true)
# -----------------------------------------------------------------------------

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="RW-Health Passport <noreply@example.com>"
SMTP_SECURE=false
