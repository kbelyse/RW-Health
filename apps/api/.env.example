NODE_ENV=development
WEB_DIST=
PORT=4000
DATABASE_URL=file:./dev.db
JWT_SECRET=local-dev-only-replace-with-random-string-32chars!!
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Outbound email (welcome, password reset, visit/lab notifications). Without these,
# the API logs email content to the console instead. On Render, set the same keys under Environment.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="RW-Health Passport <noreply@example.com>"
