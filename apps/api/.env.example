# Copy to "apps/api/.env" (npm run setup) — do not commit .env
# Values below are for LOCAL development. For Render/production, see README "Going live".

NODE_ENV=development
WEB_DIST=
PORT=4000
DATABASE_URL=file:./dev.db
JWT_SECRET=local-dev-only-replace-with-random-string-32chars!!
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:5173

# Optional email — leave SMTP_HOST empty to log emails in the terminal only
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="RW-Health Passport <noreply@example.com>"
